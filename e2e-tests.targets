<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

	<!-- E2E test targets for end-to-end testing -->

	<PropertyGroup>
		<!-- Define any global properties needed for E2E tests here -->
		<E2ELogFile>$(SolutionDir)e2e-test.log</E2ELogFile> <!-- E2E test log file -->
	</PropertyGroup>
	
	<!-- Delete E2E log file -->
	<Target Name="DELETE_E2E_LOG" DependsOnTargets="PROPERTIES">
		<Message Text="Attempting to delete log file: $(E2ELogFile)" Importance="High" />
		<Message Text="File exists: $([System.IO.File]::Exists('$(E2ELogFile)'))" Importance="High" />
		<Delete Files="$(E2ELogFile)" ContinueOnError="true">
			<Output TaskParameter="DeletedFiles" ItemName="DeletedFiles" />
		</Delete>
		<Message Text="Deleted log file: $(E2ELogFile)" Importance="High" Condition="'@(DeletedFiles)' != ''" />
		<Message Text="No log file found to delete" Importance="High" Condition="'@(DeletedFiles)' == ''" />
	</Target>

	<!-- Clean up local branches in test repositories using PowerShell -->
	<Target Name="CLEANUP_TEST_BRANCHES">
		<Message Text="Cleaning up local branches in test repositories..." Importance="high" />
		
		<!-- GitHub test repo (c:\prog\naz) -->
		<Message Text="Checking GitHub test repo (c:\prog\naz)..." Importance="high" />
		<Exec Command="powershell -Command &quot;if (Test-Path 'c:\prog\naz\.git') { cd 'c:\prog\naz'; Write-Host 'GitHub repo found'; git checkout main 2>$null; git for-each-ref --format='%(refname:short)' refs/heads | Where-Object {$_ -ne 'main'} | ForEach-Object { git branch -D $_ 2>$null } | Out-Null; Write-Host 'Cleaned GitHub repo' } else { Write-Host 'GitHub repo not found at c:\prog\naz' }&quot;" ContinueOnError="true" />
		
		<!-- Azure DevOps test repo (c:\source\ConsoleApp1) -->
		<Message Text="Checking Azure DevOps test repo (c:\source\ConsoleApp1)..." Importance="high" />
		<Exec Command="powershell -Command &quot;if (Test-Path 'c:\source\ConsoleApp1\.git') { cd 'c:\source\ConsoleApp1'; Write-Host 'Azure DevOps repo found'; git checkout main 2>$null; git for-each-ref --format='%(refname:short)' refs/heads | Where-Object {$_ -ne 'main'} | ForEach-Object { git branch -D $_ 2>$null } | Out-Null; Write-Host 'Cleaned Azure DevOps repo' } else { Write-Host 'Azure DevOps repo not found at c:\source\ConsoleApp1' }&quot;" ContinueOnError="true" />
		
		<Message Text="✓ Test repositories cleaned and ready" Importance="high" />
	</Target>

	<!-- Build test-framework library -->
	<Target Name="BUILD_E2E_FRAMEWORK" DependsOnTargets="PROPERTIES">
		<Message Text="Building test-framework library..." Importance="high" />
		<Exec Command="dotnet build test-framework\test-framework.csproj --configuration Debug"
		      WorkingDirectory="$(SolutionDir)"
		      ContinueOnError="false" />
		<Message Text="✓ test-framework built successfully" Importance="high" />
	</Target>

	<!-- Build Sdo executable -->
	<Target Name="BUILD_SDO_E2E" DependsOnTargets="BUILD_E2E_FRAMEWORK">
		<Message Text="Building sdo executable..." Importance="high" />
		<Exec Command="dotnet build Sdo\Sdo.csproj --configuration Debug"
		      WorkingDirectory="$(SolutionDir)"
		      ContinueOnError="false" />
		<Message Text="✓ sdo executable built successfully" Importance="high" />
	</Target>

	<!-- Build sdo-e2e-test executable -->
	<Target Name="BUILD_SDO_E2E_TESTS" DependsOnTargets="BUILD_SDO_E2E">
		<Message Text="Building sdo-e2e-test executable..." Importance="high" />
		<Exec Command="dotnet build sdo-e2e-test\sdo-e2e-test.csproj --configuration Debug"
		      WorkingDirectory="$(SolutionDir)"
		      ContinueOnError="false" />
		<Message Text="✓ sdo-e2e-test executable built successfully" Importance="high" />
	</Target>

	<!-- Copy sdo executable to test output directory -->
	<Target Name="COPY_SDO_EXECUTABLE" DependsOnTargets="BUILD_SDO_E2E_TESTS">
		<Message Text="Copying sdo executable and all required dependencies to test output directory..." Importance="high" />
		<ItemGroup>
			<!-- Copy sdo and its dependencies -->
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\sdo.exe" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\sdo.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\nb.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\NbuildTasks.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\GitHubRelease.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\Launcher.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\System.Configuration.ConfigurationManager.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\System.Diagnostics.EventLog.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\System.Security.Cryptography.Pkcs.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\System.Security.Cryptography.ProtectedData.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\Microsoft.Build.Framework.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\Microsoft.Build.Utilities.Core.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\Microsoft.NET.StringTools.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\System.CommandLine.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\YamlDotNet.dll" />
			<SdoFiles Include="$(SolutionDir)\Sdo\bin\Debug\sdo.deps.json" />
			<!-- NOTE: Do NOT copy sdo.runtimeconfig.json as it will overwrite sdo-e2e-test.runtimeconfig.json -->
		</ItemGroup>
		<Copy SourceFiles="@(SdoFiles)"
		      DestinationFolder="$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\"
		      SkipUnchangedFiles="true" />
		<Message Text="✓ sdo executable and dependencies copied to test directory" Importance="high" />
		<!-- Ensure runtimeconfig exists for sdo when running tests. Only copy if missing to avoid overwriting test runtimeconfig. -->
		<Copy SourceFiles="$(SolutionDir)\Sdo\bin\Debug\sdo.runtimeconfig.json"
		      DestinationFiles="$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\sdo.runtimeconfig.json"
		      SkipUnchangedFiles="true"
		      Condition="!Exists('$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\sdo.runtimeconfig.json')" />
	</Target>

	<!-- Run SDO E2E tests -->
	<Target Name="RUN_SDO_E2E_TESTS" DependsOnTargets="COPY_SDO_EXECUTABLE">
		<Message Text="Running SDO E2E tests..." Importance="high" />
		<PropertyGroup>
			<SdoE2eTestExe>.\sdo-e2e-test.exe</SdoE2eTestExe>
			<SdoE2eTestDir>$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\</SdoE2eTestDir>
		</PropertyGroup>
		<Exec Command="$(SdoE2eTestExe) test --verbose"
		      WorkingDirectory="$(SdoE2eTestDir)"
		      EnvironmentVariables="SOLUTION_DIR=$(SolutionDir)" />
		<Message Text="✓ SDO E2E tests completed" Importance="high" />
	</Target>

	<!-- Run GitHub Pipeline Creation test -->
	<Target Name="RUN_GITHUB_PIPELINE_TEST" DependsOnTargets="COPY_SDO_EXECUTABLE">
		<Message Text="Running GitHub Pipeline Creation test..." Importance="high" />
		<PropertyGroup>
			<SdoE2eTestExe>.\sdo-e2e-test.exe</SdoE2eTestExe>
			<SdoE2eTestDir>$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\</SdoE2eTestDir>
		</PropertyGroup>
		<Exec Command="$(SdoE2eTestExe) test --verbose --test-case PipelineCreate_GitHub_CreateAndVerify"
		      WorkingDirectory="$(SdoE2eTestDir)"
		      EnvironmentVariables="SOLUTION_DIR=$(SolutionDir)" />
		<Message Text="✓ GitHub Pipeline Creation test completed" Importance="high" />
	</Target>

	<!-- Run GitHub Work Item List Users test -->
	<Target Name="RUN_GITHUB_WI_LIST_USERS_TEST" DependsOnTargets="COPY_SDO_EXECUTABLE">
		<Message Text="Running GitHub Work Item List Users test..." Importance="high" />
		<PropertyGroup>
			<SdoE2eTestExe>.\sdo-e2e-test.exe</SdoE2eTestExe>
			<SdoE2eTestDir>$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\</SdoE2eTestDir>
		</PropertyGroup>
		<Exec Command="$(SdoE2eTestExe) test --verbose --test-case Validate_GitHub_ListUsers_ContainsCurrentUser"
		      WorkingDirectory="$(SdoE2eTestDir)"
		      EnvironmentVariables="SOLUTION_DIR=$(SolutionDir)" />
		<Message Text="✓ GitHub Work Item List Users test completed" Importance="high" />
	</Target>

	<!-- Run GitHub Work Item List All test -->
	<Target Name="RUN_GITHUB_WI_LIST_ALL_TEST" DependsOnTargets="COPY_SDO_EXECUTABLE">
		<Message Text="Running GitHub Work Item List All test..." Importance="high" />
		<PropertyGroup>
			<SdoE2eTestExe>.\sdo-e2e-test.exe</SdoE2eTestExe>
			<SdoE2eTestDir>$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\</SdoE2eTestDir>
		</PropertyGroup>
		<Exec Command="$(SdoE2eTestExe) test --verbose --test-case Validate_GitHub_ListAllWorkItems"
		      WorkingDirectory="$(SdoE2eTestDir)"
		      EnvironmentVariables="SOLUTION_DIR=$(SolutionDir)" />
		<Message Text="✓ GitHub Work Item List All test completed" Importance="high" />
	</Target>

	<!-- Run GitHub Work Item Assigned to Me test -->
	<Target Name="RUN_GITHUB_WI_ASSIGNED_TO_ME_TEST" DependsOnTargets="COPY_SDO_EXECUTABLE">
		<Message Text="Running GitHub Work Item Assigned to Me test..." Importance="high" />
		<PropertyGroup>
			<SdoE2eTestExe>.\sdo-e2e-test.exe</SdoE2eTestExe>
			<SdoE2eTestDir>$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\</SdoE2eTestDir>
