		<Exec Command="$(SolutionDir)\Sdo\bin\Debug\sdo.exe pipeline list" WorkingDirectory="C:\source\ConsoleApp1" ContinueOnError="true" />
		
		<Message Text="✓ sdo read-only parity tests completed" Importance="high" />
	</Target>

