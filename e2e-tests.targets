		<Exec Command="$(SolutionDir)\Sdo\bin\Debug\sdo.exe repo list --top 5" WorkingDirectory="C:\source\ConsoleApp1" ContinueOnError="true" />
		
		<Exec Command="$(SolutionDir)\Sdo\bin\Debug\sdo.exe wi list" WorkingDirectory="C:\source\ConsoleApp1" ContinueOnError="true" />
		
