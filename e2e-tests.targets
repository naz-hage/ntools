		      EnvironmentVariables="SOLUTION_DIR=$(SolutionDir)" />
		<Message Text="✓ GitHub Work Item Create Labels Verification test completed" Importance="high" />
	</Target>

	<!-- Main E2E GitHub Work Item Creation Pipeline target - runs all GitHub work item creation tests -->
	<Target Name="E2E_GITHUB_WI_CREATE" DependsOnTargets="ARTIFACTS;DELETE_E2E_LOG;RUN_GITHUB_WI_CREATE_ISSUE_TEST;RUN_GITHUB_WI_CREATE_TITLE_TEST;RUN_GITHUB_WI_CREATE_DESCRIPTION_TEST;RUN_GITHUB_WI_CREATE_LABELS_TEST">
		<Message Text="======================================" Importance="high" />
		<Message Text="✓ All GitHub Work Item Creation tests completed successfully" Importance="high" />
		<Message Text="======================================" Importance="high" />
		<Message Text="Test output log: $(E2ELogFile)" Importance="normal" />
	</Target>

	<!-- Run GitHub Work Item Start test -->
	<Target Name="RUN_GITHUB_WI_START_TEST" DependsOnTargets="COPY_SDO_EXECUTABLE">
		<Message Text="Running GitHub Work Item Start test..." Importance="high" />
		<PropertyGroup>
			<SdoE2eTestExe>$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\sdo-e2e-test.exe</SdoE2eTestExe>
