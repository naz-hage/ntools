	<!-- Run Azure DevOps Work Item Create PBI with Auto-Detection test -->
	<Target Name="RUN_AZDO_WI_CREATE_PBI_AUTO_DETECT_TEST" DependsOnTargets="COPY_SDO_EXECUTABLE">
		<Message Text="Running Azure DevOps Work Item Create PBI with Auto-Detection test..." Importance="high" />
		<PropertyGroup>
			<SdoE2eTestExe>$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\sdo-e2e-test.exe</SdoE2eTestExe>
