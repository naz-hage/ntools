	<!-- Run GitHub Work Item Create Labels Verification test -->
	<Target Name="RUN_GITHUB_WI_CREATE_LABELS_TEST" DependsOnTargets="COPY_SDO_EXECUTABLE">
		<Message Text="Running GitHub Work Item Create Labels Verification test..." Importance="high" />
		<PropertyGroup>
			<SdoE2eTestExe>$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\sdo-e2e-test.exe</SdoE2eTestExe>
		</PropertyGroup>
		<Exec Command="$(SdoE2eTestExe) test --verbose --test-case Validate_GitHub_CreatedIssueHasCorrectLabels"
