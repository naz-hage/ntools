		      WorkingDirectory="$(SdoE2eTestDir)"
		      EnvironmentVariables="SOLUTION_DIR=$(SolutionDir)" />
		<Message Text="✓ GitHub Work Item Assigned to Me test completed" Importance="high" />
	</Target>

	<!-- Run GitHub Work Item Create Issue test -->
	<Target Name="RUN_GITHUB_WI_CREATE_ISSUE_TEST" DependsOnTargets="COPY_SDO_EXECUTABLE">
		<Message Text="Running GitHub Work Item Create Issue test..." Importance="high" />
		<PropertyGroup>
			<SdoE2eTestExe>$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\sdo-e2e-test.exe</SdoE2eTestExe>
		</PropertyGroup>
		<Exec Command="$(SdoE2eTestExe) test --verbose --test-case Validate_GitHub_CreateIssueFromMarkdown"
		      WorkingDirectory="$(SolutionDir)"
		      IgnoreExitCode="false"
		      ContinueOnError="false"
		      EnvironmentVariables="SOLUTION_DIR=$(SolutionDir)" />
		<Message Text="✓ GitHub Work Item Create Issue test completed" Importance="high" />
