	</Target>

	<!-- Run GitHub Work Item Start with Verbose Mode test -->
	<Target Name="RUN_GITHUB_WI_START_VERBOSE_TEST" DependsOnTargets="COPY_SDO_EXECUTABLE">
		<Message Text="Running GitHub Work Item Start with Verbose Mode test..." Importance="high" />
		<PropertyGroup>
			<SdoE2eTestExe>$(SolutionDir)\sdo-e2e-test\bin\Debug\net10.0\sdo-e2e-test.exe</SdoE2eTestExe>
